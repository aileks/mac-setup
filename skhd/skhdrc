# focus window
ctrl - h : yabai -m window --focus west
ctrl - j : yabai -m window --focus south
ctrl - k : yabai -m window --focus north
ctrl - l : yabai -m window --focus east

# swap managed window
ctrl + alt - h : yabai -m window --swap west
ctrl + alt - j : yabai -m window --swap south
ctrl + alt - k : yabai -m window --swap north
ctrl + alt - l : yabai -m window --swap east

# resize window
ctrl + cmd - h : yabai -m window --resize right:-100:0
ctrl + cmd - j : yabai -m window --resize bottom:0:100
ctrl + cmd - k : yabai -m window --resize bottom:0:-100
ctrl + cmd - l : yabai -m window --resize right:100:0

# balance size of windows
shift + alt - 0 : yabai -m space --balance

# focus space
ctrl - 1 : yabai -m space --focus  1
ctrl - 2 : yabai -m space --focus  2
ctrl - 3 : yabai -m space --focus  3
ctrl - 4 : yabai -m space --focus  4
ctrl - 5 : yabai -m space --focus  5
ctrl - 6 : yabai -m space --focus  6
ctrl - 7 : yabai -m space --focus  7

# send window to space
shift + ctrl - 1 : yabai -m window --space  1
shift + ctrl - 2 : yabai -m window --space  2
shift + ctrl - 3 : yabai -m window --space  3
shift + ctrl - 4 : yabai -m window --space  4
shift + ctrl - 5 : yabai -m window --space  5
shift + ctrl - 6 : yabai -m window --space  6
shift + ctrl - 7 : yabai -m window --space  7

# float / unfloat window and center on screen
cmd + shift - space : yabai -m window --toggle float --grid 6:6:1:1:4:4

# apps
ctrl - return: open -n -a "Ghostty.app"
ctrl + shift - w: open -a "Arc.app"
ctrl + shift - v: open -a "Zed Preview.app"
